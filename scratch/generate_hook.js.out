  reheatingSubTitleSize: number;
  reheatingContentSize: number;
  reheatingMainTitle: string;
  airFryerTitle: string;
  ovenTitle: string;
  panTitle: string;
  portionSize: string;
  portionsPerPkg: string;
  calories: string;
  protein: string;
  fat: string;
  saturatedFat: string;
  transFat: string;
  carbs: string;
  sugar: string;
  sodium: string;
  barcodeText: string;
  expandedIngredients: Record<string, boolean>;
