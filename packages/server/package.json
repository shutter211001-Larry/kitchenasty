{
  "name": "@shutter/server",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma@5.22.0 generate --schema=../../prisma/schema.prisma && npx prisma@5.22.0 generate --schema=../../prisma/erp/shutter-erp.prisma && tsc",
    "start": "npx prisma@5.22.0 migrate deploy --schema=../../prisma/schema.prisma && npx prisma@5.22.0 migrate deploy --schema=../../prisma/erp/shutter-erp.prisma && node dist/index.js",
    "db:migrate": "npx prisma migrate dev --schema=../../prisma/schema.prisma",
    "db:migrate:shutter-erp": "npx prisma migrate dev --schema=../../prisma/erp/shutter-erp.prisma",
    "db:deploy:shutter-erp": "npx prisma migrate deploy --schema=../../prisma/erp/shutter-erp.prisma",
    "db:seed": "npx prisma db seed",
    "db:reset": "npx prisma migrate reset --schema=../../prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=../../prisma/schema.prisma",
    "db:studio:shutter-erp": "npx prisma studio --schema=../../prisma/erp/shutter-erp.prisma",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma",
    "seed": "tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.6.0",
    "@prisma/client": "^5.22.0",
    "@shutter/shared": "*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.0",
    "expo-server-sdk": "^3.13.0",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.0.0",
    "json-bigint": "^1.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^5.22.0",
    "socket.io": "^4.8.3",
    "stripe": "^20.3.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^8.3.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/json-bigint": "^1.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.10",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "vitest": "^4.0.18"
  }
}
