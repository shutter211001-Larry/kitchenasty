# ==========================================
# ⚙️ Core Configuration
# ==========================================
PORT=3000
NODE_ENV=development
CORS_ORIGINS_PUBLIC=http://localhost:5173,http://localhost:5174
STORE_URL_PUBLIC=http://localhost:5174
ERP_URL_PUBLIC=http://localhost:5175

DATABASE_URL=postgresql://shutter:shutter@localhost:5432/shutter

# ==========================================
# 🔑 Authentication
# ==========================================
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# ==========================================
# 🤖 AI Services (Gemini)
# ==========================================
# GEMINI_API_KEY=your_gemini_api_key

# ==========================================
# 🔗 Google & Social Login
# ==========================================
# GOOGLE_LOGIN_CLIENT_ID=your_google_login_client_id
# GOOGLE_LOGIN_CLIENT_SECRET=your_google_login_client_secret

# ==========================================
# 📧 Email Service
# ==========================================
# MAIL_SERVICE_TYPE=SMTP # Options: SMTP, GMAIL_API, MAILGUN
# EMAIL_FROM=Shutter <noreply@yourdomain.com>

# --- If using SMTP ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password

# --- If using GMAIL_API ---
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# --- If using MAILGUN ---
# MAILGUN_DOMAIN=your_mailgun_domain
# MAILGUN_API_KEY=your_mailgun_api_key

# ==========================================
# 💬 LINE Bot Integration
# ==========================================
# LINE_CHANNEL_SECRET=your_line_channel_secret
# LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# ==========================================
# 💳 Payments
# ==========================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# PAYPAL_SANDBOX=true

# ==========================================
# 🏢 Shutter ERP / PizzaMaster ERP Integration
# ==========================================
# SHUTTER_ERP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shutter_erp
# SHUTTER_ERP_API_URL=http://localhost:3000
# KITCHENASTY_API_URL=http://localhost:3000
# INTEGRATION_KEY=pizzamaster-integration-secret-key
