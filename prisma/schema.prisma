generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String   @id @default(cuid())
  name         String
  domain       String?  @unique
  isActive     Boolean  @default(true)
  hasErpAccess Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
  customers    Customer[]
  locations    Location[]
  categories   Category[]
  menuItems    MenuItem[]
  orders       Order[]
  coupons      Coupon[]
  siteSettings SiteSettings?

  tables                       Table[]
  reservations                 Reservation[]
  reviews                      Review[]
  loyaltyTransactions          LoyaltyTransaction[]
  groupOrderSessions           GroupOrderSession[]
  customerGroups               CustomerGroup[]
  staffPasswordResetTokens     StaffPasswordResetToken[]
  legalPages                   LegalPage[]
  cookieCategories             CookieCategory[]
  registrationBonusRecords     RegistrationBonusRecord[]
  cookieConsents               CookieConsent[]
  inviteTokens                 InviteToken[]
  automationRules              AutomationRule[]
  auditLogs                    AuditLog[]
  erpRecipeMappings            ErpRecipeMapping[]
  chatMessages                 ChatMessage[]
  staffAttendances             StaffAttendance[]
  attendanceCorrectionRequests AttendanceCorrectionRequest[]
  leaveRequests                LeaveRequest[]
  jobRoles                     JobRole[]
  userAvailabilities           UserAvailability[]
  staffTimeOffs                StaffTimeOff[]
  shiftRequirements            ShiftRequirement[]
  weeklyShiftRequirements      WeeklyShiftRequirement[]
  shifts                       Shift[]
  payrollPeriods               PayrollPeriod[]
  payslips                     Payslip[]
  payslipItems                 PayslipItem[]
  insuranceProfiles            InsuranceProfile[]
  employmentRecords            EmploymentRecord[]
  leaveBalances                LeaveBalance[]
  attendanceAnomalies          AttendanceAnomaly[]
  employeeDocuments            EmployeeDocument[]
  Ingredient                   Ingredient[]
  Supplier                     Supplier[]
  SupplierPrice                SupplierPrice[]
  Recipe                       Recipe[]
  RecipeItem                   RecipeItem[]
  RecipeOutput                 RecipeOutput[]
  RecipeStep                   RecipeStep[]
  StepParameter                StepParameter[]
  ItemParameter                ItemParameter[]
  InventoryLog                 InventoryLog[]
  Expense                      Expense[]
  ActionGroup                  ActionGroup[]
  Action                       Action[]
  UnitGroup                    UnitGroup[]
  Unit                         Unit[]
  UnitConversion               UnitConversion[]
  ErpSetting                   ErpSetting[]
  LabelManufacturer            LabelManufacturer[]

  @@map("tenants")
}

model User {
  id                  String                        @id @default(cuid())
  email               String                        @unique
  password            String
  name                String
  role                Role                          @default(STAFF)
  phone               String?
  avatar              String?
  isActive            Boolean                       @default(true)
  preferredLanguage   String                        @default("zh-TW")
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  locationId          String?
  lineDisplayName     String?
  lineUserId          String?                       @unique
  hourlyWage          Float                         @default(0)
  salaryType          SalaryType                    @default(HOURLY)
  monthlyWage         Float                         @default(0)
  maxDaysPerWeek      Int                           @default(5)
  maxHoursPerWeek     Int                           @default(40)
  assignedOrders      Order[]                       @relation("AssignedStaff")
  sentMessages        ChatMessage[]                 @relation("SentMessages")
  location            Location?                     @relation(fields: [locationId], references: [id])
  attendances         StaffAttendance[]
  correctionRequests  AttendanceCorrectionRequest[]
  approvedCorrections AttendanceCorrectionRequest[] @relation("ManagerApprovedCorrections")
  leaves              LeaveRequest[]
  approvedLeaves      LeaveRequest[]                @relation("ManagerApprovedLeaves")
  jobRoles            JobRole[]                     @relation("UserJobRoles")
  availabilities      UserAvailability[]
  timeOffs            StaffTimeOff[]
  shifts              Shift[]
  insuranceProfile    InsuranceProfile?
  employmentRecord    EmploymentRecord?
  leaveBalances       LeaveBalance[]
  payslips            Payslip[]
  documents           EmployeeDocument[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model StaffPasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("staff_password_reset_tokens")
}

model Customer {
  id                        String               @id @default(cuid())
  email                     String?              @unique
  password                  String?
  name                      String
  phone                     String?
  address                   String?
  isEmployee                Boolean              @default(false)
  isGuest                   Boolean              @default(false)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  groupId                   String?
  loyaltyPoints             Int                  @default(0)
  isWhitelisted             Boolean              @default(false)
  isBlacklisted             Boolean              @default(false)
  expoPushToken             String?
  lineDisplayName           String?
  lineUserId                String?              @unique
  facebookId                String?              @unique
  googleEmail               String?
  googleId                  String?              @unique
  emailNotificationsEnabled Boolean              @default(true)
  lineNotificationsEnabled  Boolean              @default(true)
  addresses                 Address[]
  cookieConsents            CookieConsent[]
  group                     CustomerGroup?       @relation(fields: [groupId], references: [id])
  loyaltyTransactions       LoyaltyTransaction[]
  orders                    Order[]
  reservations              Reservation[]
  reviews                   Review[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("customers")
}

model CustomerGroup {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  customers Customer[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("customer_groups")
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  label      String?
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String   @default("US")
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@map("addresses")
}

model Location {
  id                              String                   @id @default(cuid())
  name                            String
  slug                            String                   @unique
  description                     String?
  phone                           String?
  email                           String?
  address                         String
  city                            String
  state                           String?
  postalCode                      String
  country                         String                   @default("US")
  lat                             Float?
  lng                             Float?
  image                           String?
  isActive                        Boolean                  @default(true)
  deliveryEnabled                 Boolean                  @default(true)
  pickupEnabled                   Boolean                  @default(true)
  minOrderDelivery                Float                    @default(0)
  minOrderPickup                  Float                    @default(0)
  deliveryLeadTime                Int                      @default(30)
  pickupLeadTime                  Int                      @default(15)
  createdAt                       DateTime                 @default(now())
  updatedAt                       DateTime                 @updatedAt
  isBusy                          Boolean                  @default(false)
  busyMessage                     String?
  owner                           String?                  @default("未指派")
  royaltyRate                     Float?                   @default(5.0)
  hourlyNationalHolidayMultiplier Float                    @default(2.0)
  monthlyNationalHolidayOvertime  Boolean                  @default(true)
  enableOvertimePay               Boolean                  @default(true)
  overtimeMultiplier1             Float                    @default(1.34)
  overtimeMultiplier2             Float                    @default(1.67)
  restDayMultiplier               Float                    @default(1.34)
  regularDayMultiplier            Float                    @default(2.0)
  apiEndpoint                     String?
  contractStart                   String?                  @default("2025-01-01")
  contractEnd                     String?                  @default("2028-12-31")
  categories                      Category[]
  deliveryZones                   DeliveryZone[]
  mealtimes                       Mealtime[]
  menuItems                       MenuItem[]
  operatingHours                  OperatingHour[]
  orders                          Order[]
  reservations                    Reservation[]
  reviews                         Review[]
  tables                          Table[]
  staff                           User[]
  coupons                         Coupon[]
  chatMessages                    ChatMessage[]
  groupSessions                   GroupOrderSession[]
  staffAttendances                StaffAttendance[]
  jobRoles                        JobRole[]
  shiftRequirements               ShiftRequirement[]
  weeklyShiftRequirements         WeeklyShiftRequirement[]
  shifts                          Shift[]
  payrollPeriods                  PayrollPeriod[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("locations")
}

model OperatingHour {
  id         String   @id @default(cuid())
  locationId String
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("operating_hours")
}

model DeliveryZone {
  id         String   @id @default(cuid())
  locationId String
  name       String
  charge     Float    @default(0)
  minOrder   Float    @default(0)
  boundaries Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("delivery_zones")
}

model Category {
  id                      String     @id @default(cuid())
  name                    String
  slug                    String     @unique
  description             String?
  image                   String?
  sortOrder               Int        @default(0)
  isActive                Boolean    @default(true)
  isFrozenDelivery        Boolean    @default(false)
  parentId                String?
  locationId              String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  descriptionTranslations Json?
  nameTranslations        Json?
  trackSharedStock        Boolean    @default(false)
  sharedStockQty          Int        @default(0)
  sharedStockThreshold    Int        @default(5)
  location                Location?  @relation(fields: [locationId], references: [id])
  parent                  Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children                Category[] @relation("CategoryTree")
  menuItems               MenuItem[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("categories")
}

model MenuItem {
  id                      String                      @id @default(cuid())
  name                    String
  slug                    String                      @unique
  description             String?
  price                   Float
  image                   String?
  imageVariants           Json?
  cropData                Json?
  isActive                Boolean                     @default(true)
  sortOrder               Int                         @default(0)
  trackStock              Boolean                     @default(false)
  stockQty                Int                         @default(0)
  orderType               OrderType?
  categoryId              String
  locationId              String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  descriptionTranslations Json?
  nameTranslations        Json?
  unit                    String?                     @default("份")
  unitTranslations        Json?
  isRewardItem            Boolean                     @default(false)
  rewardPointsPrice       Int                         @default(0)
  allergens               MenuItemAllergen[]
  dietaryPreferences      MenuItemDietaryPreference[]
  mealtimes               MenuItemMealtime[]
  category                Category                    @relation(fields: [categoryId], references: [id])
  location                Location?                   @relation(fields: [locationId], references: [id])
  options                 MenuOption[]
  orderItems              OrderItem[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}

model MenuOption {
  id               String                @id @default(cuid())
  menuItemId       String
  name             String
  displayType      MenuOptionDisplayType @default(SELECT)
  isRequired       Boolean               @default(false)
  minSelect        Int                   @default(0)
  maxSelect        Int                   @default(1)
  sortOrder        Int                   @default(0)
  nameTranslations Json?
  values           MenuOptionValue[]
  menuItem         MenuItem              @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("menu_options")
}

model MenuOptionValue {
  id               String            @id @default(cuid())
  menuOptionId     String
  name             String
  priceModifier    Float             @default(0)
  isDefault        Boolean           @default(false)
  sortOrder        Int               @default(0)
  nameTranslations Json?
  trackStock       Boolean           @default(false)
  stockQty         Int               @default(0)
  menuOption       MenuOption        @relation(fields: [menuOptionId], references: [id], onDelete: Cascade)
  orderItemOptions OrderItemOption[]

  @@map("menu_option_values")
}

model Mealtime {
  id               String             @id @default(cuid())
  name             String
  startTime        String
  endTime          String
  days             Int[]
  isActive         Boolean            @default(true)
  locationId       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  nameTranslations Json?
  location         Location?          @relation(fields: [locationId], references: [id])
  menuItems        MenuItemMealtime[]

  @@map("mealtimes")
}

model MenuItemMealtime {
  menuItemId String
  mealtimeId String
  mealtime   Mealtime @relation(fields: [mealtimeId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([menuItemId, mealtimeId])
  @@map("menu_item_mealtimes")
}

model Allergen {
  id               String             @id @default(cuid())
  name             String             @unique
  nameTranslations Json?
  menuItems        MenuItemAllergen[]
  ingredients      Ingredient[]

  @@map("allergens")
}

model MenuItemAllergen {
  menuItemId String
  allergenId String
  allergen   Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([menuItemId, allergenId])
  @@map("menu_item_allergens")
}

model DietaryPreference {
  id               String                      @id @default(cuid())
  name             String                      @unique
  nameTranslations Json?
  menuItems        MenuItemDietaryPreference[]

  @@map("dietary_preferences")
}

model MenuItemDietaryPreference {
  menuItemId          String
  dietaryPreferenceId String
  dietaryPreference   DietaryPreference @relation(fields: [dietaryPreferenceId], references: [id], onDelete: Cascade)
  menuItem            MenuItem          @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([menuItemId, dietaryPreferenceId])
  @@map("menu_item_dietary_preferences")
}

model Order {
  id                   String               @id @default(cuid())
  orderNumber          String               @unique
  idempotencyKey       String?              @unique
  customerId           String?
  locationId           String
  addressId            String?
  orderType            OrderType
  status               OrderStatus          @default(PENDING)
  paymentStatus        String?
  subtotal             Float
  deliveryFee          Float                @default(0)
  tax                  Float                @default(0)
  discount             Float                @default(0)
  tip                  Float                @default(0)
  total                Float
  scheduledAt          DateTime?
  comment              String?
  couponId             String?
  assignedToId         String?
  guestName            String?
  guestEmail           String?
  guestPhone           String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  distance             Float?
  isRemote             Boolean              @default(false)
  pickupNumber         String?              @db.VarChar(10)
  userLat              Float?
  userLon              Float?
  language             String?              @default("zh-TW")
  trackingNumber       String?
  logisticsProvider    String?
  frozenDeliveryMethod String?
  loyaltyTransactions  LoyaltyTransaction[]
  items                OrderItem[]
  address              Address?             @relation(fields: [addressId], references: [id])
  assignedTo           User?                @relation("AssignedStaff", fields: [assignedToId], references: [id])
  coupon               Coupon?              @relation(fields: [couponId], references: [id])
  customer             Customer?            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  location             Location             @relation(fields: [locationId], references: [id])
  table                Table?               @relation(fields: [tableId], references: [id])
  tableId              String?
  groupId              String?
  groupSession         GroupOrderSession?   @relation(fields: [groupId], references: [id])
  payments             Payment[]
  reviews              Review[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
  @@index([locationId])
  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id         String            @id @default(cuid())
  orderId    String
  menuItemId String
  name       String
  quantity   Int
  unitPrice  Float
  subtotal   Float
  comment    String?
  options    OrderItemOption[]
  menuItem   MenuItem          @relation(fields: [menuItemId], references: [id])
  order      Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model OrderItemOption {
  id                String          @id @default(cuid())
  orderItemId       String
  menuOptionValueId String
  name              String
  value             String
  priceModifier     Float
  menuOptionValue   MenuOptionValue @relation(fields: [menuOptionValueId], references: [id])
  orderItem         OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_item_options")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        Float
  transactionId String?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Table {
  id            String              @id @default(cuid())
  locationId    String
  name          String
  capacity      Int
  isActive      Boolean             @default(true)
  orders        Order[]
  reservations  Reservation[]
  groupSessions GroupOrderSession[]
  location      Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([locationId, name])
  @@map("tables")
}

model Reservation {
  id         String            @id @default(cuid())
  customerId String
  locationId String
  tableId    String?
  date       DateTime          @db.Date
  time       String
  partySize  Int
  status     ReservationStatus @default(PENDING)
  comment    String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  customer   Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  location   Location          @relation(fields: [locationId], references: [id])
  table      Table?            @relation(fields: [tableId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("reservations")
}

model Coupon {
  id          String     @id @default(cuid())
  code        String?    @unique
  name        String     @default("自訂折扣活動")
  isAutomatic Boolean    @default(false)
  conditions  Json?
  locationId  String?
  type        CouponType
  value       Float
  minOrder    Float      @default(0)
  maxDiscount Float?
  usageLimit  Int?
  usageCount  Int        @default(0)
  perCustomer Int        @default(1)
  startsAt    DateTime?
  expiresAt   DateTime?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  orders      Order[]
  location    Location?  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("coupons")
}

model Review {
  id         String   @id @default(cuid())
  customerId String
  locationId String
  orderId    String?
  rating     Int
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id])
  order      Order?   @relation(fields: [orderId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  customerId  String
  type        LoyaltyTransactionType
  points      Int
  description String?
  orderId     String?
  createdAt   DateTime               @default(now())
  customer    Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order       Order?                 @relation(fields: [orderId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("loyalty_transactions")
}

model GroupOrderSession {
  id         String   @id @default(cuid())
  pin        String   @db.VarChar(4)
  locationId String
  tableId    String
  status     String   @default("ACTIVE") // ACTIVE, CHECKED_OUT, CANCELLED
  cartItems  Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  table    Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  orders   Order[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@index([tableId])
  @@index([pin])
  @@map("group_order_sessions")
}

model SiteSettings {
  id                  String   @id @default("default")
  siteName            String   @default("Shutter")
  siteTitle           String   @default("Shutter - Order Online")
  siteDescription     String   @default("Shutter - Order Online")
  favicon             String?
  logo                String?
  colorPrimary        String   @default("#ea580c")
  colorSecondary      String   @default("#9333ea")
  darkMode            String   @default("light")
  heroSection         Json?
  featuresSection     Json?
  ctaSection          Json?
  generalSettings     Json?
  orderSettings       Json?
  reservationSettings Json?
  mailSettings        Json?
  paymentSettings     Json?
  reviewSettings      Json?
  advancedSettings    Json?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
  storefrontTemplate  String   @default("classic")
  lineSettings        Json?
  menuSection         Json?
  invoiceSettings     Json?
  googleSettings      Json?
  pendingIntegrations Json?
  pendingIntegrationsToken String?

  tenantId String? @unique
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("site_settings")
}

model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("legal_pages")
}

model CookieCategory {
  id                      String          @id @default(cuid())
  name                    String          @unique
  label                   String
  labelTranslations       Json?
  description             String
  descriptionTranslations Json?
  isRequired              Boolean         @default(false)
  isActive                Boolean         @default(true)
  sortOrder               Int             @default(0)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  consents                CookieConsent[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("cookie_categories")
}

model RegistrationBonusRecord {
  id         String   @id @default(cuid())
  provider   String // 'email', 'google', 'line'
  identifier String // email or socialId
  claimedAt  DateTime @default(now())

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([provider, identifier])
  @@map("registration_bonus_records")
}

model CookieConsent {
  id               String         @id @default(cuid())
  customerId       String?
  cookieCategoryId String
  accepted         Boolean
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime       @default(now())
  cookieCategory   CookieCategory @relation(fields: [cookieCategoryId], references: [id], onDelete: Cascade)
  customer         Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("cookie_consents")
}

model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  role      Role      @default(STAFF)
  invitedBy String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

